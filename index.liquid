<style>
    .s-animation-dropdown-inner {
        background-color: #00081E !important;
        padding: 8rem 0;
    }
    .s-animation-dropdown-inner .s-container {
        max-width: 1140px;
        width: 100%;
        margin: auto;
    }
    .s-animation-dropdown-inner .s-adih-title {
        font-size: 68px;
        line-height: 110%;
        margin-bottom: 35px;
    }
    .s-animation-dropdown-inner .s-adih-subtitle {
        font-family: 'Inter';
        font-size: 14px !important;
        font-weight: 700;
        text-transform: uppercase;
        color: #1B72EC !important;
        letter-spacing: 2px;
        margin-bottom: 10px !important;
    }
    .s-animation-dropdown-inner .s-adic-row {
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        align-items: center;
    }
    .s-animation-dropdown-inner .s-adic-row > div:first-child {
        flex: 0 0 60%;
        padding-right: 60px;
    }
    .s-animation-dropdown-inner .s-adic-row > div:last-child {
        flex: 0 0 40%;
    }
    .s-animation-dropdown-inner .s-adic-feature img {
        display: block;
        max-width: 100%;
        width: 100%;
        height: auto;
        border-radius: 10px;
    }
    .s-animation-dropdown-inner .faq-question {
        font-family: 'Tw Cen MT';
        color: #30374A !important;
        font-size: 28px !important;
        font-weight: 500;
    }
    .s-animation-dropdown-inner .faq-answer {
        font-size: 16px !important;
        color: #A7AEBF !important;
        line-height: 150% !important;
    }
    .s-animation-dropdown-inner .faq-item {
        border: none !important;
    }
    .faq-item {
        display: flex;
        gap: 30px;
        padding: 15px 0;
    }
    .progress-bar {
        width: 6px;
        background: #30374A;
        position: relative;
        overflow: hidden;
        border-radius: 30px
    }
    .progress-bar span {
        position: absolute;
        top: 0;
        width: 100%;
        height: 0;
        background: #1B72EC;
    }
    .s-animation-dropdown-inner .faq-question:hover {
        color: #1B72EC !important;
    }
    .s-dyn-img img {
        transition: opacity 0.5s ease-in-out;
        opacity: 1;
    }
    .s-dyn-img img.fade-out {
        opacity: 0;
    }

    /* CONTENT */
    .faq-content {
        flex: 1;
    }
    .faq-question {
        background: none;
        border: 0;
        font-size: 18px;
        font-weight: bold;
        cursor: pointer;
        padding: 0;
        width: 100%;
        text-align: left;
    }
    .faq-answer {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.4s ease;
    }
    .faq-item.active .faq-answer {
        max-height: 300px;
        margin-top: 10px;
    }
    .faq-item.active .faq-question {
        color: #1B72EC !important;
    }
    .s-animation-dropdown-inner .s-adic-feature img {
        height: 450px;
        object-fit: cover;
    }
    @media (min-width: 821px)
    {
        .s-mobile {
            display: none !important;
        }
    }
    @media (max-width: 820px)
    {
        .s-desktop {
            display: none !important;
        }
    }
</style>

<div class="s-animation-dropdown-inner s-desktop {{ section.settings.sec_add_class }}">
    <div class="s-container">
        <div class="s-adi-heading">
            <p class="s-adih-subtitle">{{ section.settings.sec_subtitle }}</p>
            <h2 class="s-adih-title">{{ section.settings.sec_title }}</h2>
        </div>
        <div class="s-adi-content">
            <div class="s-adic-row">
                <div class="s-adic-col">
                    <div class="faq">
                        {% for block in section.blocks %}
                            {% case block.type %}
                                {% when 's_dropdown' %}
                                <div class="faq-item" data-img="{% if block.settings.d_featire != blank %}{{ block.settings.d_featire | image_url }}{% else %}https://cdn.shopify.com/s/files/1/0695/2845/3302/files/placeholder.webp{% endif %}">
                                    <div class="progress-bar"><span></span></div>
                                    <div class="faq-content">
                                        <button class="faq-question">{{ block.settings.d_title }}</button>
                                        <div class="faq-answer">{{ block.settings.d_desc }}</div>
                                    </div>
                                </div>
                            {% endcase %}
                        {% endfor %}
                    </div>
                </div>
                <div class="s-adic-col">
                    <div class="s-adic-feature s-dyn-img">
                        {% for block in section.blocks %}
                            {% if forloop.first and block.type == 's_dropdown' %}
                                {% if block.settings.d_featire  != blank %}
                                    <img src="{{ block.settings.d_featire | image_url  }}" alt="IMG" width="100%" height="100%">
                                {% else %}
                                    <img src="https://cdn.shopify.com/s/files/1/0695/2845/3302/files/placeholder.webp" alt="IMG" width="100%" height="100%">
                                {% endif %}
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="s-animation-dropdown-inner s-mobile {{ section.settings.sec_add_class }}">
    <div class="s-container">
        <div class="s-adi-heading">
            <p class="s-adih-subtitle">{{ section.settings.sec_subtitle }}</p>
            <h2 class="s-adih-title">{{ section.settings.sec_title }}</h2>
        </div>
        <div class="s-adi-content">
            <div class="s-adic-row-mbl">
                <div class="s-adic-col">
                    <div class="s-adic-feature">
                        <img src="{{ section.settings.sec_image | image_url }}" alt="IMG" width="100%" height="100%" class="s-adic-feature-img">
                    </div>
                </div>
                <div class="s-adic-col">
                    <div class="s-adic-slides">
                        <div class="splide s-adic-splide">
                            <div class="splide__track">
                                <ul class="splide__list">
                                {% for block in section.blocks %}
                                    {% case block.type %}
                                        {% when 's_dropdown' %}
                                        <div class="splide__slide" data-img_src="{% if block.settings.d_featire != blank %}{{ block.settings.d_featire | image_url }}{% else %}https://cdn.shopify.com/s/files/1/0695/2845/3302/files/placeholder.webp{% endif %}">
                                            <div class="s-adic-slide">
                                                <h3 class="s-sbox-title">{{ block.settings.d_title }}</h3>
                                                <p class="s-sbox-desc">{{ block.settings.d_desc | strip_html }}</p>
                                            </div>
                                        </div>
                                    {% endcase %}
                                {% endfor %}
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        setTimeout(function () {

            document.querySelectorAll('.s-animation-dropdown-inner').forEach(section => {

                const faq = section.querySelector('.faq');
                if (!faq) return;

                const items = faq.querySelectorAll('.faq-item');
                if (!items.length) return;

                const duration = 5000;
                let index = 0;
                let timer;
                let startTime;
                let remainingTime = duration;

                const featureWrap = section.querySelector('.s-dyn-img');
                const featureImg  = featureWrap ? featureWrap.querySelector('img') : null;
                let lastValidImg = featureImg ? featureImg.src : '';

                function resetAll() {
                    items.forEach(item => {
                        item.classList.remove('active');
                        const bar = item.querySelector('.progress-bar span');
                        bar.style.height = '0';
                        bar.style.transition = 'none';
                    });
                }

                function swapImageSmooth(newSrc) {
                    if (!featureImg) return;

                    featureImg.style.transition = 'opacity 0.5s ease-in-out';
                    featureImg.classList.add('fade-out');

                    setTimeout(() => {
                        featureImg.src = newSrc;
                        featureImg.classList.remove('fade-out');
                    }, 500);
                }

                function openItem(i, customDuration = duration) {
                    clearTimeout(timer);
                    resetAll();

                    index = i;
                    remainingTime = customDuration;

                    const item = items[i];
                    const bar  = item.querySelector('.progress-bar span');

                    item.classList.add('active');

                    if (featureImg) {
                        const newImg = item.dataset.img || lastValidImg;
                        if (newImg) {
                            lastValidImg = newImg;
                            swapImageSmooth(newImg);
                        }
                    }

                    startTime = Date.now();

                    bar.offsetHeight;
                    bar.style.transition = `height ${customDuration}ms linear`;
                    bar.style.height = '100%';

                    timer = setTimeout(() => {
                        remainingTime = duration;
                        openItem((index + 1) % items.length);
                    }, customDuration);
                }

                items.forEach((item, i) => {
                    const btn = item.querySelector('.faq-question');
                    btn.addEventListener('click', () => openItem(i));
                });

                faq.addEventListener('mouseenter', () => {

                    clearTimeout(timer);

                    const elapsed = Date.now() - startTime;
                    remainingTime = Math.max(remainingTime - elapsed, 0);

                    const item = items[index];
                    const bar = item.querySelector('.progress-bar span');

                    const computedHeight = window.getComputedStyle(bar).height;

                    bar.style.transition = 'none';
                    bar.style.height = computedHeight;

                });

                faq.addEventListener('mouseleave', () => {

                    const item = items[index];
                    const bar = item.querySelector('.progress-bar span');

                    bar.offsetHeight;
                    bar.style.transition = `height ${remainingTime}ms linear`;
                    bar.style.height = '100%';

                    startTime = Date.now();

                    timer = setTimeout(() => {
                        remainingTime = duration;
                        openItem((index + 1) % items.length);
                    }, remainingTime);

                });

                openItem(index);

            });

        }, 500);
    });
</script>

{% schema %}
{
    "name": "Animated Dropdown",
    "tag": "section",
    "class": "s--animation-dropdown-section",
    "settings": [
        {
            "type": "image_picker",
            "id": "sec_image",
            "label": "Feature Image"
        },
        {
            "type": "text",
            "id": "sec_title",
            "label": "Section Title"
        },
        {
            "type": "text",
            "id": "sec_subtitle",
            "label": "Section Sub Title"
        },
        {
            "type": "text",
            "id": "sec_add_class",
            "label": "Additional Class"
        }
    ],
    "blocks": [
        {
            "name": "Dropdown",
            "type": "s_dropdown",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "d_featire",
                    "label": "Feature Image"
                },
                {
                    "type": "text",
                    "id": "d_title",
                    "label": "Title"
                },
                {
                    "type": "textarea",
                    "id": "d_desc",
                    "label": "Description"
                }
            ]
        }
    ],
    "presets" : [
        {
            "name" : "Animated Dropdown",
            "category": "Custom SwimScore Widgets"
        }
    ]
}
{% endschema %}